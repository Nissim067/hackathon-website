# Server port for Express app.
PORT=5000

# MongoDB Atlas or local MongoDB connection string.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hackathon

# Secret key used to sign and verify JWT tokens.
JWT_SECRET=replace_with_a_long_random_secret

# Razorpay test key id for payment integration.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Razorpay test key secret for server-side payment verification.
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Email account username/address for sending tickets or notifications.
EMAIL_USER=youremail@example.com

# Email app password or SMTP password for EMAIL_USER.
EMAIL_PASS=your_email_app_password

# Deployed frontend URL used for CORS allowlist.
FRONTEND_URL=https://your-frontend-app.vercel.app
